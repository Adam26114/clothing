{
  "name": "@workspace/convex",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./_generated/api": "./_generated/api.js",
    "./_generated/api.js": "./_generated/api.js",
    "./_generated/api.d.ts": "./_generated/api.d.ts",
    "./_generated/dataModel": "./_generated/dataModel.d.ts",
    "./_generated/dataModel.d.ts": "./_generated/dataModel.d.ts",
    "./_generated/server": "./_generated/server.d.ts",
    "./_generated/server.d.ts": "./_generated/server.d.ts",
    "./*": "./*.ts"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test __tests__"
  },
  "dependencies": {
    "@auth/core": "^0.41.1",
    "@convex-dev/auth": "^0.0.94",
    "@sentry/node": "^10.60.0",
    "@workspace/lib": "workspace:*",
    "convex": "^1.41.0",
    "resend": "^6.14.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "convex-test": "^0.0.53",
    "eslint": "^9",
    "typescript": "^5"
  }
}
