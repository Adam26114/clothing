{
  "name": "@workspace/lib",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts",
    "./providers/convex": "./src/providers/convex.tsx",
    "./locales/*": "./src/locales/*"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.94",
    "@sentry/nextjs": "^10.59.0",
    "@workspace/ui": "workspace:*",
    "convex": "^1.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9",
    "typescript": "^5"
  }
}
