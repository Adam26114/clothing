{
  "name": "@workspace/lib",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "exports": {
    "./*": "./src/*.ts",
    "./providers/convex": "./src/providers/convex.tsx",
    "./locales/*": "./src/locales/*",
    "./auth/flows": "./src/auth/flows.ts",
    "./auth/use-auth": "./src/auth/use-auth.ts",
    "./cart/guest": "./src/cart/guest.ts",
    "./cart/merge": "./src/cart/merge.ts",
    "./cart/summary": "./src/cart/summary.ts",
    "./hooks/use-cart-ui": "./src/hooks/use-cart-ui.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./wishlist": "./src/wishlist.ts"
  },
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.5",
    "@dnd-kit/sortable": "^10.0.0",
    "@sentry/nextjs": "^10.59.0",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.22",
    "convex": "^1.16.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "eslint": "^9",
    "typescript": "^5"
  }
}
