# Convex
# Create a project at https://dashboard.convex.dev and grab these from the
# "Settings" tab. The deployment name is shaped like `dev:khit-clothing-<n>`.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Sentry (all are optional; the apps detect NEXT_PUBLIC_SENTRY_DSN at build
# time and skip Sentry wiring if it is absent. SENTRY_DSN is a server-side
# DSN used by Convex functions; it can be the same value as the public DSN
# or a separate one if your Sentry project supports dual DSNs.)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
# Optional — release identifier (set automatically by the `sentry-release`
# CI job on every push to main). On Vercel, set this to
# ${VERCEL_GIT_COMMIT_SHA} so each preview gets a unique release.
# SENTRY_RELEASE=
# Optional — environment label. Falls back to VERCEL_ENV, then 'development'.
# NEXT_PUBLIC_ENVIRONMENT=production
# Optional — comma-separated list of allowed Sentry project IDs for the
# /sentry-tunnel route. If unset, the tunnel accepts any project.
# SENTRY_PROJECT_IDS=4508282618429440

# Storefront URL — used by the admin proxy when redirecting unauthenticated
# users to the storefront login page.
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Admin seed (used by `bun run seed`)
SEED_ADMIN_EMAIL=zweaungnaing.info@gmail.com
SEED_ADMIN_PASSWORD=

# Optional super-admin seed — promote an existing account to super-admin or
# create a new one with role: 'super-admin'.
# SEED_SUPER_ADMIN_EMAIL=
# SEED_SUPER_ADMIN_PASSWORD=

# Resend (email verification + password reset)
# Get an API key at https://resend.com/api-keys
# Leaving these blank does not break sign-in — it just disables the verify and
# reset flows and the auth pages will show a "Resend not configured" banner.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Better Auth secret (symmetric; used to sign JWTs)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Convex site URL (https://<deployment>.convex.site) — used by
# @convex-dev/better-auth/nextjs to verify JWTs and by the BA
# auth.config.ts provider to set the JWT issuer.
NEXT_PUBLIC_CONVEX_SITE_URL=https://zealous-poodle-544.convex.site
