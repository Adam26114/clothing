{
  "name": "khit",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "predev": "bash scripts/kill-stale-dev.sh",
    "dev": "turbo dev",
    "convex:dev": "bun --filter @workspace/convex dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "format:check": "turbo format:check",
    "typecheck": "turbo typecheck",
    "test": "bun test",
    "test:convex": "bun --filter @workspace/convex test",
    "seed": "bun run scripts/seed-convex.ts",
    "seed:reset-password": "bun run scripts/seed-convex.ts --reset-password"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/tailwind-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.15",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.10",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/config/*"
  ],
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.5",
    "better-auth": "^1.6.22",
    "convex": "^1.41.0",
    "embla-carousel-react": "^8.6.0"
  }
}
